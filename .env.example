# Database Configuration
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/onboarding

# External API Keys
WORKDAY_API_KEY=your_workday_api_key_here
SERVICENOW_API_KEY=your_servicenow_api_key_here
LMS_API_KEY=your_lms_api_key_here
EMAIL_CLIENT_ID=your_email_client_id_here
EMAIL_CLIENT_SECRET=your_email_client_secret_here
I9_SYSTEM_API_KEY=your_i9_system_api_key_here
BG_CHECK_API_KEY=your_background_check_api_key_here

# AI/ML Configuration
OPENAI_API_KEY=your_openai_api_key_here
LANGCHAIN_TRACING=false

# Security Configuration
ENCRYPTION_KEY=your-32-byte-encryption-key-here-use-openssl-rand-base64-32
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Application Configuration
APP_NAME=HR Onboarding Agent
APP_VERSION=1.0.0
DEBUG=false

# SLA Configuration
DEFAULT_TASK_TIMEOUT_HOURS=24
ESCALATION_TIMEOUT_HOURS=4
MAX_RETRY_ATTEMPTS=3

# Known Jurisdictions (comma-separated)
KNOWN_JURISDICTIONS=US,CA,UK,DE,FR,AU,JP,SG